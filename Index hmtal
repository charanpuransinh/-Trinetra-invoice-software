<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Trinetra - Zero Scroll</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, sans-serif;
        }

        /* स्क्रॉल बंद करने के लिए height: 100vh और overflow: hidden */
        body {
            background: #000;
            color: #fff;
            height: 100vh;
            width: 100vw;
            overflow: hidden; 
            display: flex;
            flex-direction: column;
        }

        .container {
            width: 100%;
            max-width: 500px;
            margin: 0 auto;
            padding: 10px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between; /* ताकि सब कुछ स्क्रीन पर फैल जाए */
        }

        /* Header - थोड़ा और छोटा */
        .header {
            text-align: center;
            margin-top: 5px;
        }
        .logo {
            background: #111;
            padding: 8px 0;
            border: 2px solid #ffc107;
        }
        .logo h1 {
            font-size: 20px;
            color: #ffc107;
            letter-spacing: 2px;
        }

        /* PROFILE बॉक्स - साइज थोड़ी कम की */
        .profile-box {
            background: #111;
            border: 2px solid #ffc107;
            padding: 12px 15px;
            margin: 10px 0;
        }
        .company-name {
            font-size: 16px;
            font-weight: 700;
            color: #ffc107;
            margin-bottom: 5px;
        }
        .detail {
            font-size: 11px;
            margin-top: 3px;
            opacity: 0.9;
        }
        .divider {
            height: 1px;
            background: #ffc107;
            margin: 8px 0;
            opacity: 0.4;
        }

        /* 4 बॉक्स - Chorus & Compact */
        .grid-4 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-bottom: 10px;
        }
        .big-card {
            background: #111;
            padding: 15px 5px;
            text-align: center;
            border: 2px solid #ffc107;
        }
        .big-card .title {
            font-size: 12px;
            font-weight: 700;
            color: #000;
            background: #ffc107;
            display: block;
            padding: 2px 0;
            margin-bottom: 8px;
            text-transform: uppercase;
        }
        .big-card .value {
            font-size: 14px;
            font-weight: 700;
        }

        /* बिल बटन - फिक्स साइज */
        .btn-bill {
            margin-bottom: 15px;
        }
        .bill-generate {
            background: #ffc107;
            color: #000;
            border: none;
            padding: 12px;
            font-size: 16px;
            font-weight: 800;
            width: 100%;
            text-transform: uppercase;
        }

        /* नीचे 5 आइकन */
        .bottom-nav {
            background: #080808;
            display: flex;
            justify-content: space-around;
            align-items: center;
            padding: 10px 0;
            border-top: 2px solid #ffc107;
            width: 100%;
        }
        .nav-item {
            text-align: center;
            flex: 1;
            font-size: 10px;
            color: #fff;
            text-decoration: none;
        }
        .nav-item.active { color: #ffc107; }
        .nav-item span { display: block; font-size: 20px; }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div class="logo">
            <h1>🔱 TRISHUL 🔱</h1>
        </div>
    </div>

    <div class="profile-box">
        <div class="company-name">🏢 TRINETRA SOFTWARE</div>
        <div class="detail">📞 +91 98765 43210</div>
        <div class="detail">📍 RAJKOT, GUJARAT</div>
        <div class="divider"></div>
        <div class="detail">🆔 GST: 24ABCDE1234F1Z</div>
    </div>

    <div class="grid-4">
        <div class="big-card"><span class="title">पार्टी</span><div class="value">राम एंटरप्राइजेस</div></div>
        <div class="big-card"><span class="title">आइटम</span><div class="value">स्टील / सीमेंट</div></div>
        <div class="big-card"><span class="title">अकाउंट</span><div class="value">₹ 24,500</div></div>
        <div class="big-card"><span class="title">डैशबोर्ड</span><div class="value">मैनेजमेंट</div></div>
    </div>

    <div class="btn-bill">
        <button class="bill-generate">📄 बिल जनरेशन</button>
    </div>
</div>

<nav class="bottom-nav">
    <a href="#" class="nav-item active"><span>🏠</span>होम</a>
    <a href="#" class="nav-item"><span>👥</span>पार्टी</a>
    <a href="#" class="nav-item"><span>🧾</span>बिल</a>
    <a href="#" class="nav-item"><span>📦</span>आइटम</a>
    <a href="#" class="nav-item"><span>👤</span>प्रोफाइल</a>
</nav>
</body>
</html>
